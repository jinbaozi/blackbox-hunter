      "needs_network": true
    },
    {
      "name": "yara",
      "version_min": "4.0",
      "install_cmds": {
        "apt": "sudo apt-get install -y yara",
        "brew": "brew install yara"
      },
      "detect_cmd": "yara --version",
      "category": "pattern_scan",
      "priority": "high",
      "fallbacks": [],
      "platform": ["linux", "darwin"],
      "needs_network": false
    },
    {
      "name": "lintian",
      "version_min": "2.0",
      "install_cmds": {
        "apt": "sudo apt-get install -y lintian"
      },
      "detect_cmd": "lintian --version",
      "category": "config_audit",
      "priority": "high",
      "fallbacks": [],
