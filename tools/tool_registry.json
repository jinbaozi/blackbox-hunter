{
  "registry_version": 1,
  "tools": [
    {
      "name": "cve-bin-tool",
      "version_min": "3.0",
      "install_cmds": {
        "apt": "pip install cve-bin-tool",
        "brew": "pip install cve-bin-tool",
        "fallback": "pip install --user cve-bin-tool"
      },
      "detect_cmd": "cve-bin-tool --version",
      "category": "cve_scan",
      "priority": "required",
      "fallbacks": ["trivy", "grype"],
      "platform": ["linux", "darwin"],
      "needs_network": true
    },
    {
      "name": "checksec",
      "version_min": "2.0",
      "install_cmds": {
        "apt": "sudo apt-get install -y checksec",
        "brew": "brew install checksec",
        "fallback": "pip install checksec"
      },
      "detect_cmd": "checksec --version",
      "category": "hardening",
      "priority": "required",
      "fallbacks": ["hardening-check"],
      "platform": ["linux", "darwin"],
      "needs_network": false
    },
    {
      "name": "cwe_checker",
      "version_min": "0.7",
      "install_cmds": {
        "docker": "docker pull fkiecad/cwe_checker"
      },
      "detect_cmd": "docker run --rm fkiecad/cwe_checker --version",
      "category": "binary_defect",
      "priority": "high",
      "fallbacks": ["radare2"],
      "platform": ["linux"],
      "needs_network": true
    },
    {
      "name": "binwalk",
      "version_min": "2.3",
