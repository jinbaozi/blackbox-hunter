      },
      "detect_cmd": "rpmlint --version",
      "category": "config_audit",
      "priority": "high",
      "fallbacks": [],
      "platform": ["linux"],
      "applies_to": "rpm",
      "needs_network": false
    },
    {
      "name": "radare2",
      "version_min": "5.0",
      "install_cmds": {
        "apt": "sudo apt-get install -y radare2",
